Host *
    ForwardAgent yes

{{ if eq .chezmoi.os "darwin" }}

# Use the 1Password SSH agent only when its socket exists on this machine.
Match host * exec "test -S \"$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock\""
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

Host forge
  HostName forge
  User joe
  ForwardAgent yes

Host forge-tmux
  HostName forge
  User joe
  ForwardAgent yes
  RequestTTY force
  RemoteCommand tmux new-session -A -s main

{{ end }}
