[user]
	name = {{ get . "git_name" | default "Joe Horne" | quote }}
	email = {{ get . "git_email" | default "change-me@example.com" | quote }}

[include]
	path = ~/.gitconfig.local

[core]
	autocrlf = input
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between diff sections

    # delta detects terminal colors automatically; set one of these to disable auto-detection
    # dark = true
    # light = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
